# ══════════════════════════════════════════════════════════
# CONFIGURACIÓN DEL SERVIDOR FARMATICKET - EJEMPLO
# Copia este archivo a .env y edita los valores
# ══════════════════════════════════════════════════════════

# Puerto del servidor (por defecto 3000)
PORT=3000

# Configuración de Base de Datos MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=tu_contraseña_mysql_aqui
DB_NAME=farmaticket

# Opcional: Configuración adicional
# JWT_SECRET=genera_una_clave_secreta_aleatoria
# NODE_ENV=development
